# =============================================================
# Integration Test Environment — PDF.it
# =============================================================
# Copy this file to .env.test and fill in your credentials.
# .env.test is already in .gitignore — never commit it.
#
# IMPORTANT: Use a SEPARATE Supabase project for tests.
# Do NOT use your production Supabase credentials here.
# =============================================================

# --- Test Supabase Project ---
NEXT_PUBLIC_SUPABASE_URL=https://your-test-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-test-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-test-service-role-key

# --- Stripe Test Mode ---
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret

# --- Stripe Price IDs (test mode) ---
STRIPE_PRICE_ID=price_test_pro_monthly
STRIPE_PRICE_ID_ANNUAL=price_test_pro_annual
STRIPE_PRICE_ID_BUSINESS=price_test_business_monthly
STRIPE_PRICE_ID_BUSINESS_ANNUAL=price_test_business_annual
STRIPE_PRICE_ID_ENTERPRISE=price_test_enterprise_monthly
STRIPE_PRICE_ID_ENTERPRISE_ANNUAL=price_test_enterprise_annual

# --- hCaptcha Test Keys (always pass) ---
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
HCAPTCHA_SECRET_KEY=0x0000000000000000000000000000000000000000

# --- Cron Secret ---
CRON_SECRET=test-cron-secret-12345

# --- Mock paid APIs (no real calls) ---
MOCK_EXTERNAL_APIS=true
ILOVEAPI_PUBLIC_KEY=test_dummy
ILOVEAPI_SECRET_KEY=test_dummy
CLOUDCONVERT_API_KEY=test_dummy

# --- Disable rate limiting ---
# (leave KV_REST_API_URL and KV_REST_API_TOKEN unset)

# --- Site URL ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
